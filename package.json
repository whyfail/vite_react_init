{
  "name": "{{ name }}",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "description": "{{ description }}",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "start": "node scripts/start.js",
    "build": "node scripts/build.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:junit": "vitest run --reporter=junit --outputFile=test-results/vitest-junit.xml",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:component-coverage": "node scripts/check-component-tests.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "ahooks": "^3.9.7",
    "animate.css": "^4.1.1",
    "autoprefixer": "^10.5.2",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "immer": "^11.1.11",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.23.0",
    "million": "^3.1.11",
    "ogl": "^1.0.11",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@eslint-react/eslint-plugin": "^5.11.2",
    "@playwright/test": "^1.61.1",
    "@plugin-web-update-notification/vite": "^2.1.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/devtools": "^0.3.4",
    "@vitejs/devtools-kit": "^0.3.4",
    "@vitejs/devtools-self-inspect": "^0.3.4",
    "@vitejs/plugin-legacy": "^8.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "code-inspector-plugin": "^1.6.5",
    "eslint": "^10.6.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "less": "^4.6.7",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "react-grab": "^0.1.48",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unplugin-printer": "^0.0.2",
    "vite": "^8.1.3",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-no-bug": "^1.0.5",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "node scripts/verify-commit.js $1"
  },
  "lint-staged": {
    "*": "eslint --fix --no-warn-ignored"
  }
}
